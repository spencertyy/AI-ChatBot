# docker compose 用的环境变量模板。
# 复制成 .env.docker 后填入真实值：cp .env.docker.example .env.docker

# --- PostgreSQL 容器的初始化参数 ---
POSTGRES_USER=aichat
POSTGRES_PASSWORD=change_me_local_pw
POSTGRES_DB=aichat

# --- 应用连接数据库的串 ---
# 注意 host 是 db（compose 里的服务名），不是 localhost！
DATABASE_URL=postgresql://aichat:change_me_local_pw@db:5432/aichat

# --- AI 提供商 key（从你的 .env.local 复制过来）---
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- NextAuth / Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
